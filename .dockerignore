node_modules/
static/dist/
.git/
__pycache__/
*.pyc
*.pyo
.env
.env.*

# The biggest offender — Stage 2 is Python-only, never needs node_modules
node_modules/

# Old build artifacts — Stage 2 gets a fresh copy from --from=frontend anyway
static/dist/

# Python bytecode
__pycache__/
**/*.pyc
**/*.pyo

# TLS certs — shouldn't be baked into the image; mount these at runtime
certs/

# Misc
tree.txt
*.log